# =============================================================================
# Easterseals Iowa Volunteer Scheduler — Environment Variables
# =============================================================================
# Copy this file to `.env` for local development and fill in the blanks.
# `.env` is gitignored — never commit real secrets.
#
# Scope tags on each section tell you WHERE the variable is consumed:
#   [frontend]  — read by Vite at build time, inlined into the bundle
#                 (therefore visible to every browser — NEVER secrets here)
#   [edge]      — read by Supabase Edge Functions at runtime via
#                 `Deno.env.get(...)` — set via `supabase secrets set ...`
#                 in production, and in `supabase/.env.local` for local
#                 edge-function dev
#   [ci]        — read only by GitHub Actions workflows; never set locally
#   [dashboard] — configured directly in the Supabase project dashboard
#                 (not consumed from process env) — listed here for
#                 completeness of the operator handoff
# =============================================================================


# -----------------------------------------------------------------------------
# [frontend] Supabase client
# -----------------------------------------------------------------------------
# These get inlined into the browser bundle. Use the ANON (publishable) key,
# never the service_role key. The URL and publishable key are safe to expose.
VITE_SUPABASE_URL=
VITE_SUPABASE_PUBLISHABLE_KEY=

# -----------------------------------------------------------------------------
# [frontend] Observability
# -----------------------------------------------------------------------------
# Sentry DSN is a public identifier — safe to ship in the client. Leave
# blank in local dev to disable Sentry entirely (the init function is
# gated on the presence of this var).
VITE_SENTRY_DSN=

# App version tag used in Sentry release tracking. Normally injected by CI
# from the git SHA, but can be set locally to any string for testing.
VITE_APP_VERSION=

# -----------------------------------------------------------------------------
# [frontend] Cloudflare Turnstile (bot protection)
# -----------------------------------------------------------------------------
# The Turnstile widget's public site key. Paired with a SECRET key that
# lives in the Supabase dashboard (see [dashboard] section below).
VITE_TURNSTILE_SITE_KEY=

# -----------------------------------------------------------------------------
# [edge] Supabase — auto-injected in production
# -----------------------------------------------------------------------------
# These three are populated automatically in the hosted edge-function
# runtime. You only need to set them in `supabase/.env.local` when running
# `supabase functions serve` locally.
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# -----------------------------------------------------------------------------
# [edge] Email — MailerSend
# -----------------------------------------------------------------------------
# API key from the MailerSend dashboard. FROM_EMAIL must be a verified
# sender on a verified domain (or the MailerSend sandbox subdomain).
MAILERSEND_API_KEY=
MAILERSEND_FROM_EMAIL=

# Local dev safety valves. When EMAIL_SANDBOX=true AND EMAIL_SANDBOX_REDIRECT
# is a real address, every outbound email is rewritten to that address so
# you can test templates without spamming real volunteers.
EMAIL_SANDBOX=false
EMAIL_SANDBOX_REDIRECT=

# -----------------------------------------------------------------------------
# [edge] SMS — Twilio
# -----------------------------------------------------------------------------
# SMS is currently disabled in production (Twilio trial account — unverified
# destination numbers fail). Set SMS_ENABLED=true once the account is
# upgraded and the sending number is verified.
SMS_ENABLED=false
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=

# -----------------------------------------------------------------------------
# [dashboard] Cloudflare Turnstile — server-side verification
# -----------------------------------------------------------------------------
# Supabase Auth verifies Turnstile tokens natively when CAPTCHA is enabled
# in the project dashboard (Authentication → Sign In → CAPTCHA Protection).
# The secret key is set there, NOT as an env var. Listed here as a reminder
# for operators setting up a new environment.
# TURNSTILE_SECRET_KEY=(set in Supabase dashboard, not in env)

# -----------------------------------------------------------------------------
# [ci] Deployment — GitHub Actions only
# -----------------------------------------------------------------------------
# Never set these locally. They live in GitHub → Settings → Secrets, and
# in Dependabot secrets (duplicated, per Dependabot's isolation rules).
VERCEL_TOKEN=
VERCEL_ORG_ID=
VERCEL_PROJECT_ID=

# Supabase CLI access token — used by the deploy workflow to link the
# project before running `supabase gen types typescript --linked`.
SUPABASE_ACCESS_TOKEN=

# -----------------------------------------------------------------------------
# [ci] E2E test credentials — GitHub Actions only
# -----------------------------------------------------------------------------
# Playwright specs create/cancel shifts against a shared production DB as
# these test users. They are gated behind an E2E role guard — do not use
# for anything else. Never set these locally.
TEST_VOLUNTEER_EMAIL=
TEST_COORDINATOR_EMAIL=
TEST_ADMIN_EMAIL=
TEST_PASSWORD=

# -----------------------------------------------------------------------------
# [ci] Android signing — GitHub Actions only
# -----------------------------------------------------------------------------
# Consumed by .github/workflows/android.yml to sign the TWA APK.
ANDROID_KEYSTORE_BASE64=
ANDROID_KEYSTORE_PASSWORD=
ANDROID_KEY_PASSWORD=
