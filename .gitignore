# Supabase CLI local state — per-clone, should never be committed.
supabase/.branches/
supabase/.temp/

# Android signing key — never commit this.
# The historical paths below were previously committed to git history in
# commit e66d0b3 (Apr 7, 2026) and purged via history rewrite (494 commits
# rewritten, force-push to main). Keeping them ignored here prevents a
# re-accident if the same filenames are regenerated.
*.jks
android-release-key.jks
android-release-key.jks.bak
android/android.keystore
android/*.jks
android/*.keystore
android/app-release-bundle.aab
android/app-release-signed.apk
android/app-release-signed.apk.idsig
android/app-release-unsigned-aligned.apk
android/app-release*.apk
android/app-release*.aab
android/build/
android/app/build/
android/.gradle/
